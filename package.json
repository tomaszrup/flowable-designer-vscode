{
  "name": "bpmn-designer-vscode",
  "publisher": "TomaszRup",
  "displayName": "BPMN Designer ported from Flowable Eclipse Designer",
  "description": "VS Code BPMN editor compatible with legacy Eclipse Flowable Designer files",
  "version": "0.0.9",
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tomaszrup/flowable-designer-vscode"
  },
  "homepage": "https://github.com/tomaszrup/flowable-designer-vscode#readme",
  "bugs": {
    "url": "https://github.com/tomaszrup/flowable-designer-vscode/issues"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "browser": "./dist/web/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "flowable-bpmn",
        "aliases": [
          "Flowable BPMN",
          "BPMN"
        ],
        "extensions": [
          ".bpmn",
          ".bpmn2",
          ".bpmn20.xml"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "flowable-bpmn",
        "scopeName": "text.xml.bpmn",
        "path": "./syntaxes/bpmn.tmLanguage.json"
      }
    ],
    "customEditors": [
      {
        "viewType": "flowable-bpmn-designer.editor",
        "displayName": "Flowable BPMN Designer",
        "selector": [
          {
            "filenamePattern": "*.bpmn"
          },
          {
            "filenamePattern": "*.bpmn2"
          },
          {
            "filenamePattern": "*.bpmn20.xml"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "flowable-bpmn-designer.newDiagram",
        "title": "Flowable BPMN Designer: New BPMN Diagram"
      },
      {
        "command": "flowable-bpmn-designer.exportImage",
        "title": "Flowable BPMN Designer: Export Diagram Image"
      },
      {
        "command": "flowable-bpmn-designer.validate",
        "title": "Flowable BPMN Designer: Validate BPMN"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "flowable-bpmn",
          "title": "Flowable BPMN",
          "icon": "resources/flowable-icon.svg"
        }
      ]
    },
    "views": {
      "flowable-bpmn": [
        {
          "id": "flowable-bpmn-designer.processNavigator",
          "name": "Process Navigator",
          "icon": "resources/flowable-icon.svg",
          "when": "resourceExtname == .bpmn || resourceExtname == .bpmn2"
        }
      ]
    },
    "configuration": {
      "title": "Flowable BPMN Designer",
      "properties": {
        "flowableBpmnDesigner.imageExport.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Automatically export a diagram image (SVG) when saving."
        },
        "flowableBpmnDesigner.imageExport.format": {
          "type": "string",
          "default": "svg",
          "enum": [
            "svg"
          ],
          "description": "Image export format."
        },
        "flowableBpmnDesigner.imageExport.overlay.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Add an overlay with metadata to exported images."
        },
        "flowableBpmnDesigner.imageExport.overlay.showProcessKey": {
          "type": "boolean",
          "default": true,
          "description": "Show process key in the overlay."
        },
        "flowableBpmnDesigner.imageExport.overlay.showNamespace": {
          "type": "boolean",
          "default": true,
          "description": "Show target namespace in the overlay."
        },
        "flowableBpmnDesigner.imageExport.overlay.showFilename": {
          "type": "boolean",
          "default": true,
          "description": "Show filename in the overlay."
        },
        "flowableBpmnDesigner.imageExport.overlay.showDate": {
          "type": "boolean",
          "default": true,
          "description": "Show export date in the overlay."
        },
        "flowableBpmnDesigner.imageExport.overlay.color": {
          "type": "string",
          "default": "#999999",
          "description": "Overlay text color."
        },
        "flowableBpmnDesigner.imageExport.overlay.backgroundColor": {
          "type": "string",
          "default": "#ffffff",
          "description": "Overlay background color."
        },
        "flowableBpmnDesigner.validation.validateOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically validate BPMN on save and report issues in the Problems panel."
        },
        "flowableBpmnDesigner.editor.minimap": {
          "type": "boolean",
          "default": false,
          "description": "Show the minimap overlay on the BPMN canvas."
        },
        "flowableBpmnDesigner.editor.defaultLanguage": {
          "type": "string",
          "default": "en",
          "description": "Default language for new localizations."
        },
        "flowableBpmnDesigner.editor.availableLanguages": {
          "type": "array",
          "default": [
            "en",
            "de",
            "fr",
            "es",
            "nl",
            "pl"
          ],
          "items": {
            "type": "string"
          },
          "description": "Available languages for the localization editor."
        }
      }
    }
  },
  "scripts": {
    "test": "vitest run",
    "vscode:prepublish": "npm run package-web",
    "package:vsix": "vsce package",
    "copy-bpmn-assets": "shx mkdir -p dist/webview/bpmn-assets/bpmn-font && shx cp node_modules/bpmn-js/dist/assets/diagram-js.css dist/webview/bpmn-assets/ && shx cp -r node_modules/bpmn-js/dist/assets/bpmn-font/css dist/webview/bpmn-assets/bpmn-font/ && shx cp -r node_modules/bpmn-js/dist/assets/bpmn-font/font dist/webview/bpmn-assets/bpmn-font/ && shx cp node_modules/diagram-js-minimap/assets/diagram-js-minimap.css dist/webview/bpmn-assets/",
    "compile-web": "npm run check-types && npm run lint && npm run build:vite:extension && npm run build:vite:webview && npm run copy-bpmn-assets",
    "watch-web": "npm-run-all -p watch-web:*",
    "watch-web:vite:extension": "vite build --watch --config vite.extension.config.ts",
    "watch-web:vite:webview": "vite build --watch --config vite.webview.config.ts",
    "watch-web:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package-web": "npm run check-types && npm run lint && npm run build:vite:extension -- --mode production && npm run build:vite:webview -- --mode production && npm run copy-bpmn-assets",
    "build:vite:extension": "vite build --config vite.extension.config.ts",
    "build:vite:webview": "vite build --config vite.webview.config.ts",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "run-in-browser": "vscode-test-web --browserType=chromium --extensionDevelopmentPath=. ."
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@vscode/test-web": "^0.0.80",
    "@vscode/vsce": "^3.6.2",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "shx": "^0.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.9.9",
    "bpmn-js": "^18.14.0",
    "diagram-js-minimap": "^5.3.0"
  }
}
