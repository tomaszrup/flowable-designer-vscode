{
	"compilerOptions": {
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"target": "ES2020",
		"outDir": "dist",
		"types": [],
		"lib": [
			"ES2020", "DOM", "WebWorker"
		],
		"sourceMap": true,
		"rootDir": "src",
		"skipLibCheck": true,
		"strict": true,   /* enable all strict type-checking options */
		/* Additional Checks */
		"noImplicitReturns": true,
		"noFallthroughCasesInSwitch": true,
	},
	"include": [
		"src/**/*"
	],
	"exclude": [
		"dist",
		"node_modules"
	]
}
